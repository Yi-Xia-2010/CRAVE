    # [Scene: Harborfront — Late Afternoon]
    hide rafi_soto
    hide maya_kestrel

    scene bg ch15_f99e88_3 at full_bg
    # play sound "sfx_placeholder"  # [Sound: The creak of the planks underfoot; a distant crane moving crates; neighbors murmuring in clusters]
